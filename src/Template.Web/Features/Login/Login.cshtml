@model Template.Web.Features.Login.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MarcTempo - Login</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/marc-tempo.css" asp-append-version="true" />
</head>

<body class="marc-login-body">
    <main class="marc-login-page">
        <header class="marc-login-header">
            <div class="marc-brand">
                <div class="marc-brand-name">MarcTempo</div>
                <div class="marc-brand-anchor">⚓</div>
            </div>

            <h1>Portale Aziendale</h1>
        </header>

        <section class="marc-login-content">
            <div class="marc-login-card">
                <h2>Effettua il Login</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post" action="@Url.Action("Login", "Login")">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", autocomplete = "email", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", autocomplete = "current-password" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    <div class="marc-forgot-password">
                        <a href="javascript:void(0)">Password dimenticata?</a>
                    </div>

                    <button type="submit" class="btn marc-btn-primary w-100">
                        Accedi
                    </button>
                </form>
            </div>
        </section>

        <footer class="marc-footer">
            <div>Sede amministrativa e operativa: Via dei Matti, 0 - 99999 - Isola Evanescente</div>
            <div>Sede legale: Via dei Matti, 1 - 99999 - Isola Evanescente</div>
            <div>Registro Imprese XXX - Partita IVA e codice fiscale: 000111222333</div>
            <div>
                <a class="marc-footer-link" href="@Url.Action("Privacy", "Login")">
                    Informativa privacy e gestione dati
                </a>
            </div>
        </footer>
    </main>
</body>
</html>